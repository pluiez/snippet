{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Snippet",
  "version": "0.1.0",
  "identifier": "app.snippet",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Snippet",
        "width": 900,
        "height": 640,
        "minWidth": 600,
        "minHeight": 400,
        "visible": false,
        "resizable": true
      },
      {
        "label": "palette",
        "title": "Snippet Palette",
        "width": 800,
        "height": 520,
        "decorations": false,
        "alwaysOnTop": true,
        "center": true,
        "visible": false,
        "skipTaskbar": true,
        "resizable": false
      },
      {
        "label": "onboarding",
        "title": "Snippet 初始设置",
        "width": 560,
        "height": 480,
        "center": true,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
